@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>This is the Client Application.</p>
    @if (User.Identity?.IsAuthenticated != true)
    {
        <p>Please <a asp-controller="Auth" asp-action="Login">Login</a> or <a asp-controller="Auth" asp-action="Register">Register</a> to continue.</p>
    }
    else
    {
        <p>You are logged in as <strong>@User.Identity.Name</strong>.</p>
    }
</div>